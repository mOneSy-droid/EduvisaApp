# OPENAI_API_KEY: Required for OpenAI API calls (AI Konsultant chat funksiyasi uchun).
# https://platform.openai.com/api-keys manzilidan olishingiz mumkin.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL bazasiga ulanish manzili.
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# Lokal (Windows, pgAdmin/psql orqali o'rnatilgan) baza uchun misol:
# DATABASE_URL="postgresql://postgres:sizning_parolingiz@localhost:5432/eduvisa"
DATABASE_URL="postgresql://postgres:password@localhost:5432/eduvisa"

# DB_SSL: Hosting'dagi (Render, Railway, Neon, Supabase) bazalar odatda SSL talab qiladi -> true
# Lokal kompyuteringizdagi PostgreSQL uchun -> false
DB_SSL="false"

# TELEGRAM_BOT_TOKEN: BotFather'dan olinadigan haqiqiy bot tokeni.
# Bo'sh qoldirilsa, bot ishga tushmaydi (faqat "Sahifaga qaytish" avtomatik kirish ishlaydi).
TELEGRAM_BOT_TOKEN=""

# TELEGRAM_BOT_USERNAME: Bot foydalanuvchi nomi (@ belgisiz), deep-link yaratish uchun.
TELEGRAM_BOT_USERNAME="Eduvisa_ai_bot"

# TELEGRAM_ADMIN_CHAT_ID: Yangi ro'yxatdan o'tishlar haqida xabar keladigan admin chat ID.
# O'z chat ID'ingizni bilish uchun @userinfobot ga /start yozing.
TELEGRAM_ADMIN_CHAT_ID=""
